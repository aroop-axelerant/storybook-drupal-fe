{#
  Undergraduate Courses template — Regent's University London

  Props:
    header       — Site header (variant, logo, nav, cta)
    hero         — Editorial hero (title, subtitle)
    breadcrumb   — Array of { label, href } (href null = current page)
    filters      — { year_options[], field_options[] }
    courses      — Array of { title, qualification, badge, href }
    apply_journey — { heading, overline, body, cards[] { step, heading, summary, image, cta, bodyBg } }
    newsletter   — { eyebrow, heading, body, placeholder, submit }
    footer       — Site footer
#}

<div class="t-ug-courses">

  {# ── Header ───────────────────────────────────────────────────────── #}
  {% include "@components/header/header.twig" with { variant: header.variant, logo: header.logo, nav: header.nav, cta: header.cta } %}

  {# ── Hero ─────────────────────────────────────────────────────────── #}
  <section class="ug-hero">
    <div class="layout-container">
      <h1 class="ug-hero__title">{{ hero.title }}</h1>
      <p class="ug-hero__subtitle">{{ hero.subtitle }}</p>
    </div>
  </section>

  {# ── Breadcrumb ───────────────────────────────────────────────────── #}
  <div class="courses-breadcrumb">
    {% include "@components/breadcrumb/breadcrumb.twig" with { items: breadcrumb } %}
  </div>

  {# ── Listing section ──────────────────────────────────────────────── #}
  <section class="ug-listing">
    <div class="layout-container">

      {# Mobile: filter trigger row #}
      <div class="ug-listing__mobile-bar">
        <div class="ug-search">
          <svg class="ug-search__icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
          <input class="ug-search__input" type="search" placeholder="Search courses…" aria-label="Search courses">
        </div>
        <button class="ug-filter-btn" aria-controls="ug-drawer" aria-expanded="false">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="4" y1="6" x2="20" y2="6"/><line x1="8" y1="12" x2="16" y2="12"/><line x1="11" y1="18" x2="13" y2="18"/></svg>
          Filters
        </button>
      </div>

      <div class="layout-listing">

        {# ── Sidebar ──────────────────────────────────────────────── #}
        <aside class="layout-listing__sidebar">
          <div class="ug-filters">
            <div class="ug-filters__header">
              <span class="ug-filters__title">Filters</span>
              <button class="ug-filters__reset" type="button">Reset Filters</button>
            </div>
            <div role="group" aria-labelledby="legend-year">
              <p id="legend-year" class="ug-filter-group__legend">Academic Year Start</p>
              <div class="check-list">
                {% for opt in filters.year_options %}
                  <label class="check-group">
                    <input class="check-input" type="checkbox" name="start" value="{{ opt.value }}"{% if opt.checked %} checked{% endif %}>
                    <span class="check-box" aria-hidden="true"></span>
                    <span class="check-label">{{ opt.label }}</span>
                  </label>
                {% endfor %}
              </div>
            </div>
            <div role="group" aria-labelledby="legend-field">
              <p id="legend-field" class="ug-filter-group__legend">Subject Area</p>
              <div class="check-list">
                {% for opt in filters.field_options %}
                  <label class="check-group">
                    <input class="check-input" type="checkbox" name="field" value="{{ opt.value }}"{% if opt.checked %} checked{% endif %}>
                    <span class="check-box" aria-hidden="true"></span>
                    <span class="check-label">{{ opt.label }}</span>
                  </label>
                {% endfor %}
              </div>
            </div>
          </div>
        </aside>

        {# ── Main ─────────────────────────────────────────────────── #}
        <div class="layout-listing__main">

          {# Desktop search #}
          <div class="ug-search ug-search--desktop">
            <svg class="ug-search__icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
            <input class="ug-search__input" type="search" placeholder="Search courses…" aria-label="Search courses">
          </div>

          {# Course list #}
          <ol class="ug-course-list">
            {% for course in courses %}
              <li class="ug-course-row">
                <a class="ug-course-row__link" href="{{ course.href }}">
                  <div class="ug-course-row__left">
                    <span class="ug-course-row__title">{{ course.title }}</span>
                    {% if course.badge %}
                      <span class="ug-course-row__badge ug-course-row__badge--{{ course.badge == 'Foundation' ? 'violet' : 'green' }}">{{ course.badge }}</span>
                    {% endif %}
                  </div>
                  <span class="ug-course-row__qual">{{ course.qualification }}</span>
                </a>
              </li>
            {% endfor %}
          </ol>

        </div>
      </div>
    </div>
  </section>

  {# ── Mobile filter drawer ─────────────────────────────────────────── #}
  <div class="ug-drawer-backdrop" id="ug-backdrop" aria-hidden="true"></div>
  <div class="ug-drawer" id="ug-drawer" role="dialog" aria-modal="true" aria-label="Filter courses" hidden>
    <div class="ug-drawer__header">
      <span class="ug-drawer__title">Filters</span>
      <button class="ug-drawer__close" aria-label="Close filters">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    </div>
    <div class="ug-drawer__body">
      <div class="ug-filters">
        <div role="group" aria-labelledby="legend-year-m">
          <p id="legend-year-m" class="ug-filter-group__legend">Academic Year Start</p>
          <div class="check-list">
            {% for opt in filters.year_options %}
              <label class="check-group">
                <input class="check-input" type="checkbox" name="start-m" value="{{ opt.value }}"{% if opt.checked %} checked{% endif %}>
                <span class="check-box" aria-hidden="true"></span>
                <span class="check-label">{{ opt.label }}</span>
              </label>
            {% endfor %}
          </div>
        </div>
        <div role="group" aria-labelledby="legend-field-m">
          <p id="legend-field-m" class="ug-filter-group__legend">Subject Area</p>
          <div class="check-list">
            {% for opt in filters.field_options %}
              <label class="check-group">
                <input class="check-input" type="checkbox" name="field-m" value="{{ opt.value }}"{% if opt.checked %} checked{% endif %}>
                <span class="check-box" aria-hidden="true"></span>
                <span class="check-label">{{ opt.label }}</span>
              </label>
            {% endfor %}
          </div>
        </div>
      </div>
    </div>
    <div class="ug-drawer__footer">
      <button class="ug-drawer__apply">Apply Filters</button>
      <button class="ug-drawer__reset">Reset</button>
    </div>
  </div>

  {# ── Journey cards ────────────────────────────────────────────────── #}
  {# ── How to Apply ─────────────────────────────────────────────────── #}
  <section class="t-section" aria-label="{{ apply_journey.heading }}">
    <div class="t-section__inner">
      <div class="section-header">
        {% if apply_journey.overline %}<span class="section-header__overline">{{ apply_journey.overline }}</span>{% endif %}
        <h2 class="section-header__heading">{{ apply_journey.heading }}</h2>
        {% if apply_journey.body %}<p class="section-header__body">{{ apply_journey.body }}</p>{% endif %}
      </div>
      <div class="cards-grid">
        {% for card in apply_journey.cards %}
          <article class="card card--step-count">
            <div class="card__step-image">
              <img src="{{ card.image.src }}" alt="{{ card.image.alt }}" loading="lazy">
            </div>
            <div class="card__body card__body--{{ card.bodyBg }}">
              <span class="card__step-label">{{ card.step }}</span>
              <h3 class="card__heading">
                <a href="{{ card.cta.href }}" class="card__heading-link">{{ card.heading }}</a>
              </h3>
              <p class="card__excerpt">{{ card.summary }}</p>
              <a href="{{ card.cta.href }}" class="card__step-cta" tabindex="-1" aria-hidden="true">
                {{ card.cta.label }}
              </a>
            </div>
          </article>
        {% endfor %}
      </div>
    </div>
  </section>

  {# ── Newsletter ───────────────────────────────────────────────────── #}
  <section class="ug-newsletter">
    <div class="layout-container">
      <div class="ug-newsletter__inner">
        <div class="ug-newsletter__copy">
          <span class="ug-eyebrow">{{ newsletter.eyebrow }}</span>
          <h2 class="ug-newsletter__heading">{{ newsletter.heading }}</h2>
          <p class="ug-newsletter__body">{{ newsletter.body }}</p>
        </div>
        <form class="ug-newsletter__form" action="#" method="post">
          <input class="ug-newsletter__input" type="email" placeholder="{{ newsletter.placeholder }}" aria-label="{{ newsletter.placeholder }}" required>
          <button class="ug-newsletter__submit" type="submit">{{ newsletter.submit }}</button>
        </form>
      </div>
    </div>
  </section>

  {# ── Footer ───────────────────────────────────────────────────────── #}
  {% include "@components/footer/footer.twig" with { brand: footer.brand, columns: footer.columns, social: footer.social, legal: footer.legal, copyright: footer.copyright } %}

</div>
