{#
 * Radio Button component — Regent's University London
 *
 * Props:
 * - id:       string   Input id
 * - label:    string   Visible label
 * - name:     string   Radio group name
 * - value:    string   Input value
 * - checked:  boolean  Pre-selected state
 * - disabled: boolean  Disabled state
 * - error:    boolean  Error state
 #}
<label class="radio-group">
  <input
    class="radio-input{% if error %} radio-input--error{% endif %}"
    type="radio"
    id="{{ id }}"
    name="{{ name }}"
    {% if value %}value="{{ value }}"{% endif %}
    {% if checked %}checked{% endif %}
    {% if disabled %}disabled{% endif %}
    {% if error %}aria-invalid="true"{% endif %}>
  <span class="radio-circle" aria-hidden="true"></span>
  <span class="radio-label{% if disabled %} radio-label--disabled{% endif %}">{{ label }}</span>
</label>
