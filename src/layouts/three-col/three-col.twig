{#
 * Three-column layout — Regent's University London
 *
 * Props:
 * - variant: string  equal | quad | auto  (default: equal)
 * - items:   array of { content: string }  (slot — column HTML per item)
 #}
<div class="layout-three-col{% if variant and variant != 'equal' %} layout-three-col--{{ variant }}{% endif %}">
  {% for item in items %}
    <div class="layout-three-col__item">{{ item.content }}</div>
  {% endfor %}
</div>
