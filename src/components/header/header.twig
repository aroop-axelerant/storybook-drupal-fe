{#
 * Site Header component — Regent's University London
 * Glassmorphic two-pill fixed navigation.
 *
 * Props:
 * - variant:  string   light | dark    (default: light)
 * - scrolled: boolean  Adds shadow on scroll
 * - logo:     { src, alt }
 * - nav:      array of { label, href, has_dropdown }
 * - cta:      { label, href }          (optional)
 #}
<header
  class="site-header site-header--{{ variant|default('light') }}{% if scrolled %} site-header--scrolled{% endif %}"
  role="banner"
>
  <!-- Left pill: logo + primary navigation -->
  <div class="site-header__pill">
    <a href="/" class="site-header__logo" aria-label="{{ logo.alt|default('Regent\\'s University London home') }}">
      <img src="{{ logo.src|default('/assets/full-logo.svg') }}" alt="{{ logo.alt|default('Regent\\'s University London') }}" />
    </a>
    <div class="site-header__pill-divider" aria-hidden="true"></div>
    <nav aria-label="Primary navigation">
      <ul class="site-header__nav">
        {% for item in nav %}
          <li>
            <a
              href="{{ item.href }}"
              class="site-header__nav-link"
              {% if item.has_dropdown %}aria-haspopup="true" aria-expanded="false"{% endif %}
            >{{ item.label }}</a>
          </li>
        {% endfor %}
      </ul>
    </nav>
  </div>

  <!-- Right pill: CTA + utilities -->
  <div class="site-header__pill">
    {% if cta %}
      {% include "@components/button/button.twig" with { label: cta.label, href: cta.href, variant: "primary", size: "sm" } %}
    {% endif %}
    <button class="site-header__icon-btn" aria-label="Search" type="button">
      <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
        <circle cx="8" cy="8" r="5.5" stroke="currentColor" stroke-width="1.5"/>
        <path d="M12.5 12.5L16 16" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      </svg>
    </button>
    <button class="site-header__icon-btn" aria-label="Open menu" aria-expanded="false" aria-controls="mega-menu" type="button">
      <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
        <path d="M2 4h14M2 9h14M2 14h14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      </svg>
    </button>
  </div>
</header>
