{#
  Footer component
  @prop {string} description   - Brand tagline shown below the logo
  @prop {array}  social_links  - Social icon links: label, href, icon
  @prop {array}  nav_columns   - Navigation column groups: heading, links[], contact_items[]
  @prop {string} copyright     - Copyright notice string
  @prop {array}  legal_links   - Bottom legal link items: label, href
#}

<footer class="site-footer" aria-label="Site footer">

  {# ── Main content ──────────────────────────────────────────────────────── #}
  <div class="site-footer__main">
    <div class="site-footer__inner">

      {# Brand column #}
      <div class="site-footer__brand">
        <a href="/" class="site-footer__logo-link" aria-label="Regent's University London home">
          <svg class="site-footer__logo" viewBox="0 0 220 60" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <circle cx="18" cy="30" r="16" stroke="currentColor" stroke-width="1.5" fill="none"/>
            <circle cx="18" cy="30" r="10" stroke="currentColor" stroke-width="1" fill="none"/>
            <path d="M12 24 L18 18 L24 24 M12 36 L18 42 L24 36 M10 30 H26" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
            <text x="42" y="25" font-family="Avenir Next, sans-serif" font-weight="700" font-size="16" fill="currentColor" letter-spacing="3">REGENT'S</text>
            <text x="42" y="42" font-family="Avenir Next, sans-serif" font-weight="400" font-size="9" fill="currentColor" letter-spacing="4">UNIVERSITY LONDON</text>
          </svg>
        </a>

        {% if description %}
          <p class="site-footer__description">{{ description }}</p>
        {% endif %}

        {% if social_links %}
          <ul class="site-footer__social" aria-label="Social media links">
            {% for item in social_links %}
              <li>
                <a href="{{ item.href }}" class="site-footer__social-link" aria-label="{{ item.label }}" target="_blank" rel="noopener noreferrer">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    {# Icon paths injected per icon name via JS/Twig logic #}
                  </svg>
                </a>
              </li>
            {% endfor %}
          </ul>
        {% endif %}
      </div>

      {# Navigation columns #}
      {% if nav_columns %}
        {% for col in nav_columns %}
          <nav class="site-footer__nav-col" aria-label="{{ col.heading }}">
            <h3 class="site-footer__nav-heading">{{ col.heading }}</h3>

            {% if col.links %}
              <ul class="site-footer__nav-list">
                {% for link in col.links %}
                  <li><a href="{{ link.href }}" class="site-footer__nav-link">{{ link.label }}</a></li>
                {% endfor %}
              </ul>
            {% endif %}

            {% if col.contact_items %}
              <ul class="site-footer__contact-list">
                {% for item in col.contact_items %}
                  <li class="site-footer__contact-item">
                    <a href="{{ item.href }}" class="site-footer__contact-link">{{ item.label }}</a>
                  </li>
                {% endfor %}
              </ul>
            {% endif %}
          </nav>
        {% endfor %}
      {% endif %}

    </div>
  </div>

  {# ── Legal bar ─────────────────────────────────────────────────────────── #}
  <div class="site-footer__legal-bar">
    <div class="site-footer__inner">
      <p class="site-footer__copyright">{{ copyright }}</p>
      {% if legal_links %}
        <ul class="site-footer__legal-links" aria-label="Legal links">
          {% for link in legal_links %}
            <li><a href="{{ link.href }}" class="site-footer__legal-link">{{ link.label }}</a></li>
          {% endfor %}
        </ul>
      {% endif %}
    </div>
  </div>

</footer>
