{#
 * Button component — Regent's University London
 *
 * Props:
 * - label:     string   Button text (omit for icon-only)
 * - variant:   string   primary | primary-inverse | secondary | secondary-inverse | ghost | ghost-inverse | icon-fill | icon-outline | icon-ghost
 * - icon:      string   Optional icon name (arrow | search | plus)
 * - aria_label:string   Required for icon-only buttons
 * - disabled:  boolean  Disabled state (default: false)
 * - type:      string   button | submit | reset (default: button)
 #}
<button
  class="btn btn--{{ variant|default('primary') }}"
  type="{{ type|default('button') }}"
  {% if disabled %}disabled{% endif %}
  {% if aria_label %}aria-label="{{ aria_label }}"{% endif %}>
  {% if label %}{{ label }}{% endif %}
  {% if icon %}
    {# SVG icon rendered via include or inline #}
  {% endif %}
</button>
