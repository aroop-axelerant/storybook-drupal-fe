{#
  Video component
  @prop {string} title           - Video title shown in the thumbnail caption
  @prop {string} attribution     - Speaker name and institution
  @prop {string} youtube_id      - YouTube video ID (used to build embed URL)
  @prop {string} thumbnail_src   - Path to thumbnail image (optional; falls back to gradient bg)
  @prop {string} thumbnail_alt   - Alt text for the thumbnail image
#}

<div class="video{% if variant == 'compact' %} video--compact{% endif %}">

  {# ── Thumbnail ──────────────────────────────────────────────────────────── #}
  <div class="video__thumbnail">

    {% if thumbnail_src %}
      <img
        class="video__thumbnail-img"
        src="{{ thumbnail_src }}"
        alt="{{ thumbnail_alt }}"
        aria-hidden="{{ thumbnail_alt ? 'false' : 'true' }}"
      >
    {% endif %}

    <button
      class="video__play"
      type="button"
      aria-label="Play video: {{ title }}"
    >
      <span class="video__play-icon" aria-hidden="true">
        <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
          <polygon points="6,4 20,12 6,20" fill="currentColor"/>
        </svg>
      </span>
    </button>

    {% if variant != 'compact' %}
    <div class="video__caption">
      <p class="video__title">{{ title }}</p>
      {% if attribution %}
        <p class="video__attribution">{{ attribution }}</p>
      {% endif %}
    </div>
    {% endif %}

  </div>

  {# ── Modal ──────────────────────────────────────────────────────────────── #}
  <div
    class="video__modal"
    role="dialog"
    aria-modal="true"
    aria-label="{{ title }}"
    aria-hidden="true"
    hidden
  >
    <div class="video__modal-inner">

      <button
        class="video__modal-close"
        type="button"
        aria-label="Close video"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="18" y1="6" x2="6" y2="18"/>
          <line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      </button>

      <div class="video__embed-wrap">
        <iframe
          class="video__iframe"
          data-src="https://www.youtube.com/embed/{{ youtube_id }}"
          src=""
          title="{{ title }}"
          frameborder="0"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
          allowfullscreen
        ></iframe>
      </div>

    </div>
  </div>

</div>
