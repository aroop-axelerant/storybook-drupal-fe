{#
 * Button component — Regent's University London
 * Mirrors button.stories.js HTML exactly.
 *
 * Props:
 * - label:    string   Button / link text
 * - variant:  string   primary | primary-inverted | secondary-inverted |
 *                      outline-dark | outline-green | ghost   (default: primary)
 * - size:     string   sm | md | lg                           (default: md)
 * - type:     string   button | submit | reset                (default: button)
 * - disabled: boolean
 * - href:     string   If set, renders as <a> tag
 * - icon:     string   SVG markup for icon (optional)
 #}
{% if href %}
  <a
    href="{{ href }}"
    class="btn btn--{{ variant|default('primary') }} btn--{{ size|default('md') }}"
    {% if disabled %}aria-disabled="true"{% endif %}
  >
    {% if icon %}<span class="btn__icon" aria-hidden="true">{{ icon }}</span>{% endif %}
    <span class="btn__label">{{ label }}</span>
  </a>
{% else %}
  <button
    type="{{ type|default('button') }}"
    class="btn btn--{{ variant|default('primary') }} btn--{{ size|default('md') }}"
    {% if disabled %}disabled aria-disabled="true"{% else %}aria-disabled="false"{% endif %}
  >
    {% if icon %}<span class="btn__icon" aria-hidden="true">{{ icon }}</span>{% endif %}
    <span class="btn__label">{{ label }}</span>
  </button>
{% endif %}
